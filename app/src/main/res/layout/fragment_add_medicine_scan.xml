<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC071424"
    android:fitsSystemWindows="true">

    <!-- Main Scanner Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Title -->
        <LinearLayout
            android:id="@+id/headerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_camera_alt"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Quét Mã Vạch"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Scanner Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/scannerCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#071B33"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Camera Preview -->
                <androidx.camera.view.PreviewView
                    android:id="@+id/cardViewFinder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:scaleType="fillCenter" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.45"
                    android:background="#071B33" />

                <!-- Top Buttons -->
                <ImageView
                    android:id="@+id/btn_close_scan"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_circle_light_blue"
                    android:backgroundTint="#1AFFFFFF"
                    android:padding="10dp"
                    android:src="@drawable/ic_close"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/btn_flashlight"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="18dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/bg_circle_light_blue"
                    android:backgroundTint="#1AFFFFFF"
                    android:padding="10dp"
                    android:src="@drawable/ic_flash_off"
                    app:tint="@color/white" />

                <!-- Barcode Scan Area -->
                <FrameLayout
                    android:layout_width="250dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center">

                    <!-- Border -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_barcode_frame" />

                    <!-- Red Laser -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="center"
                        android:background="#FF2D2D" />
                </FrameLayout>

                <!-- Instruction Box -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginHorizontal="32dp"
                    android:layout_marginBottom="80dp"
                    android:background="@drawable/bg_tab_unselected"
                    android:backgroundTint="#0F223B"
                    android:gravity="center"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:text="Di chuyển mã vạch của hộp thuốc vào bên trong khung nét đứt để hệ thống nhận diện"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </FrameLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>